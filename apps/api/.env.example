# Runtime
NODE_ENV=development
PORT=3333

# Mongo
# IMPORTANTE: o débito atômico de créditos usa transações Mongo (session.withTransaction).
# Transações exigem replica set. Em dev local, use docker com `--replSet rs0` + rs.initiate(),
# ou aponte pro seu cluster Atlas.
MONGODB_URI=mongodb://localhost:27017/lucida

# BetterAuth
# AUTH_SECRET: 32+ bytes random. Gerar com: openssl rand -base64 32
AUTH_SECRET=change-me-to-32-random-bytes-in-base64
# AUTH_BASE_URL: URL pública que o browser vê (Next app, pois usamos rewrite proxy)
AUTH_BASE_URL=http://localhost:3000
# WEB_ORIGIN: origin do frontend (trustedOrigin + CORS)
WEB_ORIGIN=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Redirect URI a registrar: {AUTH_BASE_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP (verificação de email, reset de senha, convites, recibos de billing)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Lucida <contato@lucidaexam.com>"

# Destinatário do formulário de "Ajuda e suporte" (/app/ajuda).
# Fallback: contato@lucidaexam.com.
SUPPORT_EMAIL=contato@lucidaexam.com

# OpenAI (geração de questões)
OPENAI_API_KEY=
# Modelo default — gpt-4o-mini é barato e rápido; gpt-4o pra qualidade.
OPENAI_MODEL=gpt-4o-mini

# OMR Service (Python/FastAPI — scanner de folha de respostas).
# Sem essa URL, as rotas de scan devolvem 502.
OMR_SERVICE_URL=http://localhost:8001
OMR_SERVICE_TIMEOUT_MS=60000

# ─────────────────────────────────────────────────────────────
# Billing — créditos, assinaturas e top-ups
# ─────────────────────────────────────────────────────────────

# Quantidade de créditos concedidos a cada novo usuário no signup.
# Uma prova de 10 questões custa ~25 créditos → 150 dá ~6 provas pra teste.
WELCOME_CREDITS=150

# Stripe — todos opcionais em dev. Sem STRIPE_SECRET_KEY, checkout/portal
# devolvem 503, mas welcome credits + gating continuam funcionando.
# Chaves em: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Obtido via `stripe listen --forward-to localhost:3333/v1/billing/webhook`
STRIPE_WEBHOOK_SECRET=

# Price IDs dos 4 planos de assinatura (criar no Stripe Dashboard):
# — Mensal: R$ 49,90 (básico) / R$ 99,90 (pro)
# — Anual:  R$ 479,00 (básico) / R$ 959,00 (pro)
STRIPE_BASIC_MONTHLY_PRICE_ID=
STRIPE_BASIC_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=

# Price IDs dos 3 top-ups (modo "payment" no Stripe, não subscription):
# — Início: R$ 29,90 / 2.000 créditos
# — Plus:   R$ 59,90 / 5.000 créditos
# — Power:  R$ 139,90 / 15.000 créditos
STRIPE_TOPUP_2K_PRICE_ID=
STRIPE_TOPUP_5K_PRICE_ID=
STRIPE_TOPUP_15K_PRICE_ID=

# ─────────────────────────────────────────────────────────────
# AbacatePay — PIX (top-ups)
# ─────────────────────────────────────────────────────────────
# Stripe não libera PIX pra nossa conta, então o caminho PIX usa AbacatePay.
# Cartão (assinatura + topup por cartão) segue 100% no Stripe acima.
# Sem ABACATEPAY_API_KEY, a rota POST /v1/billing/topup/pix devolve 503.
# Painel: https://www.abacatepay.com/
ABACATEPAY_API_KEY=
# Secret enviado como query param ?webhookSecret=... pelo painel da
# AbacatePay. Mínimo 16 chars (gerar com: openssl rand -hex 24).
# Sem ABACATEPAY_WEBHOOK_SECRET, a rota POST /v1/billing/abacatepay/webhook devolve 503.
ABACATEPAY_WEBHOOK_SECRET=

# Cron interno — expiração diária de wallets vencidas.
# Qualquer string ≥ 16 chars (gerar com: openssl rand -hex 24).
# Sem esse env, a rota POST /v1/internal/expire-credits devolve 503.
CRON_SECRET=
