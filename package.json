{
  "name": "lucida-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "dev:api": "pnpm --filter @lucida/api dev",
    "dev:web": "pnpm --filter @lucida/web dev",
    "build": "pnpm -r --parallel --stream build",
    "start": "pnpm -r --parallel --stream start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  }
}
